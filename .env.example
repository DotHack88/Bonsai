# Copia questo file in .env e riempi i valori

# URL del proxy API per lo sviluppo locale
# In produzione Vercel lascia VUOTO (o rimuovi la riga) → usa la serverless /api/claude
REACT_APP_API_URL=http://localhost:3004

# Chiave API Anthropic Claude — SOLO SERVER, mai nel client!
# Ottieni la chiave da: https://console.anthropic.com/account/keys
# Su Vercel: aggiungi come Secret con nome "claude_api_key"
CLAUDE_API_KEY=sk-ant-xxx...
